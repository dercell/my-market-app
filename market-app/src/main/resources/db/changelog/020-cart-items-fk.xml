<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="20" author="sergey.kolotev">
        <preConditions onFail="HALT">
            <tableExists tableName="cart"/>
            <tableExists tableName="items"/>
            <columnExists tableName="cart" columnName="item_id"/>
            <columnExists tableName="items" columnName="id"/>
        </preConditions>
        <addForeignKeyConstraint
                baseTableName="cart"
                baseColumnNames="item_id"
                constraintName="fk_cart_items_id"
                referencedTableName="items"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
        <rollback>
            <dropForeignKeyConstraint baseTableName="cart" constraintName="fk_cart_items_id"/>
        </rollback>
    </changeSet>
</databaseChangeLog>