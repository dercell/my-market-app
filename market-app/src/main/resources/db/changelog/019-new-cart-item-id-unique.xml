<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="19" author="sergey.kolotev">
        <preConditions onFail="HALT">
            <and>
                <columnExists tableName="cart" columnName="item_id"/>
                <columnExists tableName="cart" columnName="user_id"/>
            </and>
        </preConditions>
        <addUniqueConstraint tableName="cart" columnNames="user_id, item_id" constraintName="cart_item_id_unq"/>
        <rollback>
            <dropForeignKeyConstraint baseTableName="cart" constraintName="cart_item_id_unq"/>
        </rollback>
    </changeSet>
</databaseChangeLog>